# Local dev:
# Leave VITE_API_URL unset to use Vite proxy: /api -> http://localhost:8000
# VITE_API_URL=http://localhost:8000/api

# Production fallback (used when VITE_API_URL is unset and mode is production):
# Can be with or without /api; code normalizes it.
VITE_RENDER_API_URL=https://insuranceandtax.onrender.com
